rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is authenticated (Optional for future)
    function isAuthenticated() {
      return request.auth != null;
    }

    // Default: allow reading for all 
    match /{document=**} {
      allow read: if true;
    }

    // Define rules for users
    match /users/{userId} {
      // Users can write to their own document (e.g. updating profile)
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /teams/{teamId} {
      // Users can create/update their own teams
      allow write: if request.auth != null;
      // You can add more granular checks, e.g., request.resource.data.userId == request.auth.uid
    }

    // Define strictly Admin-controlled collections
    // Replace 'ADMIN_UID_HERE' with your actual Firebase Authentication UID later
    // For now, if we don't have server-side admin validation yet, we relax it slightly, 
    // BUT the best practice is checking request.auth.uid or a custom claim.
    
    function isAdmin() {
      // Temporary: uncomment and set your UID for full production lockdown
      // return request.auth != null && request.auth.uid == 'ADMIN_UID_HERE';
      return request.auth != null; // For staging purposes, allows logged-in users to act as admin. CHANGE PRIOR TO PRODUCTION.
    }

    match /matches/{matchId} {
      allow write: if isAdmin();
    }
    match /live_updates/{matchId} {
      allow write: if isAdmin();
    }
    match /players/{playerId} {
      allow write: if isAdmin();
    }
    match /contests/{contestId} {
      allow write: if isAdmin();
    }
    match /ai_picks/{matchId} {
      allow write: if isAdmin();
    }
    match /teams/{teamId} {
      allow write: if isAdmin();
    }

  }
}
